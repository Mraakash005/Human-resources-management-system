# ═══════════════════════════════════════════════════════════════
# HRMS Environment Variables — .env.example
# Copy this to .env and fill in all values
# ═══════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────
APP_NAME=HRMS Enterprise
APP_VERSION=3.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
LOG_LEVEL=INFO

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hrms:hrms_secure_password_2025@localhost:5432/hrms_db

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Clerk Authentication ───────────────────────────────────────
# Get from: https://dashboard.clerk.com > Your App > API Keys
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
# Get from: https://dashboard.clerk.com > Your App > JWT Templates > Edit > PEM format
CLERK_JWT_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----"
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Email (Resend) ─────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=hrms@yourdomain.com
HR_EMAIL=hr@yourdomain.com

# ── AI: Ollama ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3
OLLAMA_CHATBOT_MODEL=mistral

# ── AI: Whisper ────────────────────────────────────────────────
WHISPER_URL=http://localhost:9000

# ── File Upload / ClamAV ───────────────────────────────────────
CLAMAV_URL=http://localhost:3310

# ── R2 Object Storage (Profile Pictures) ───────────────────────
# Get from: https://dash.cloudflare.com > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=hrms-assets
R2_PUBLIC_BASE_URL=https://your-bucket.your-r2-domain.com

# ── Geofence ───────────────────────────────────────────────────
OFFICE_LAT=12.9716
OFFICE_LNG=77.5946
GEOFENCE_RADIUS_METERS=150

# ── Company ────────────────────────────────────────────────────
COMPANY_NAME=Your Company Ltd

# ── PostgreSQL (for docker-compose) ────────────────────────────
POSTGRES_PASSWORD=hrms_secure_password_2025

# ── ngrok (Docker only — provides public tunnel for Clerk webhooks) ──
# Set NGROK_ENABLED=true to start ngrok with `docker compose --profile ngrok up`
# Get your authtoken at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_ENABLED=false
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_REGION=us
